{
  "name": "rawafid",
  "version": "0.1.0",
  "description": "المنظومة الوطنية للتكامل المؤسسي وسلاسل القيمة للجمعيات الأهلية",
  "private": true,
  "author": {
    "name": "جمعية جود الإسكان",
    "email": "info@rawafid.sa",
    "url": "https://rawafid.sa"
  },
  "license": "MIT",
  "keywords": [
    "ngo",
    "saudi-arabia",
    "social-impact",
    "vision-2030",
    "housing",
    "integration"
  ],
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "start": "node dist/server.js",
    "lint": "eslint src --ext .js,.ts,.jsx,.tsx --fix",
    "lint:check": "eslint src --ext .js,.ts,.jsx,.tsx",
    "format": "prettier --write \"src/**/*.{js,ts,jsx,tsx,css,md}\"",
    "format:check": "prettier --check \"src/**/*.{js,ts,jsx,tsx,css,md}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "db:migrate": "node scripts/migrate.js",
    "db:seed": "node scripts/seed.js",
    "db:reset": "node scripts/reset.js",
    "prepare": "husky install",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.1",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "zod": "^3.22.4",
    "pg": "^8.11.3",
    "ioredis": "^5.3.2",
    "nodemailer": "^6.9.9",
    "winston": "^3.11.0",
    "helmet": "^7.1.0",
    "express-rate-limit": "^7.1.5",
    "multer": "^1.4.5-lts.1"
  },
  "devDependencies": {
    "@types/node": "^20.11.5",
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/pg": "^8.11.0",
    "@types/nodemailer": "^6.4.14",
    "typescript": "^5.3.3",
    "vite": "^5.0.12",
    "vitest": "^1.2.2",
    "@vitest/coverage-v8": "^1.2.2",
    "@playwright/test": "^1.41.2",
    "eslint": "^8.56.0",
    "@typescript-eslint/eslint-plugin": "^6.20.0",
    "@typescript-eslint/parser": "^6.20.0",
    "eslint-plugin-import": "^2.29.1",
    "prettier": "^3.2.5",
    "husky": "^9.0.10",
    "lint-staged": "^15.2.2"
  },
  "lint-staged": {
    "*.{js,ts,jsx,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{css,md,json}": [
      "prettier --write"
    ]
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged",
      "commit-msg": "commitlint --edit $1"
    }
  }
}
