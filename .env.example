# ============================================================
# Environment Variables — روافد / Rawafid
# Copy this file to .env and fill in your values
# NEVER commit .env to version control
# ============================================================

# ──────────────────────────────────────────
# Application
# ──────────────────────────────────────────
APP_NAME=Rawafid
APP_ENV=development          # development | staging | production
APP_PORT=3000
APP_URL=http://localhost:3000
APP_SECRET_KEY=change-me-to-a-long-random-string-min-32-chars

# ──────────────────────────────────────────
# Database (PostgreSQL)
# ──────────────────────────────────────────
DATABASE_URL=postgresql://rawafid_user:password@localhost:5432/rawafid_db
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# ──────────────────────────────────────────
# Cache (Redis)
# ──────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_TTL_SECONDS=3600

# ──────────────────────────────────────────
# Authentication / JWT
# ──────────────────────────────────────────
JWT_SECRET=change-me-to-another-long-random-string
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_REFRESH_EXPIRES_IN=30d

# ──────────────────────────────────────────
# Email Service
# ──────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@example.com
SMTP_PASS=your-email-password
EMAIL_FROM=noreply@rawafid.sa
EMAIL_FROM_NAME=روافد

# ──────────────────────────────────────────
# File Storage (S3 Compatible)
# ──────────────────────────────────────────
STORAGE_DRIVER=local          # local | s3 | azure
S3_BUCKET=rawafid-files
S3_REGION=me-south-1
S3_ACCESS_KEY=your-access-key
S3_SECRET_KEY=your-secret-key
S3_ENDPOINT=https://s3.me-south-1.amazonaws.com

# ──────────────────────────────────────────
# Logging
# ──────────────────────────────────────────
LOG_LEVEL=info                # debug | info | warn | error
LOG_FORMAT=json               # json | pretty

# ──────────────────────────────────────────
# Features Flags
# ──────────────────────────────────────────
FEATURE_DIGITAL_PLATFORM=false
FEATURE_KPI_DASHBOARD=false
FEATURE_VALUE_CHAINS=false

# ──────────────────────────────────────────
# External APIs
# ──────────────────────────────────────────
# مركز دعم الجمعيات API
NCSC_API_URL=https://api.ncsc.gov.sa
NCSC_API_KEY=your-ncsc-api-key

# ──────────────────────────────────────────
# Monitoring (Optional)
# ──────────────────────────────────────────
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
